# =========================================
# 몽글픽 추천 서비스 환경변수 템플릿
# =========================================
# 이 파일을 .env 로 복사한 뒤 실제 값을 입력하세요.
# cp .env.example .env

# -----------------------------------------
# 애플리케이션 기본 설정
# -----------------------------------------
APP_NAME=monglepick-recommend
APP_VERSION=0.1.0
DEBUG=true
API_V1_PREFIX=/api/v1
# SQL 쿼리 로그 출력 여부 (v1 SQLAlchemy + v2 aiomysql 양쪽 적용)
# 개발: true 권장 / 운영: 반드시 false (민감 파라미터 노출 + 성능 저하)
SQL_ECHO=false

# -----------------------------------------
# MySQL (Spring Boot 백엔드와 공유)
# -----------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# -----------------------------------------
# Redis
# -----------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# -----------------------------------------
# JWT (Spring Boot 백엔드와 동일한 시크릿 사용)
# -----------------------------------------
# backend application.yml 기본값과 동일하게 맞춰둡니다.
# 운영에서는 반드시 환경변수로 같은 값으로 오버라이드하세요.
JWT_SECRET=monglepick-dev-jwt-secret-key-must-be-at-least-256-bits-long-for-hs256
JWT_ALGORITHM=HS256

# -----------------------------------------
# 서버
# -----------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8001

# -----------------------------------------
# CORS 허용 오리진
# -----------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------
# TMDB 이미지 베이스 URL
# -----------------------------------------
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500

# -----------------------------------------
# Elasticsearch 검색
# -----------------------------------------
# SEARCH_ES_ENABLED=true 일 때만 ES 검색 경로를 사용합니다.
# 미설정/접속 실패/인덱스 누락 시에는 MySQL로 자동 폴백합니다.
SEARCH_ES_ENABLED=false
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=movies_bm25

# -----------------------------------------
# OCR — Upstage Document AI
# -----------------------------------------
# https://console.upstage.ai 에서 발급한 API 키
UPSTAGE_API_KEY=your_upstage_api_key_here
# OCR 요청 타임아웃 (초, 기본 30)
UPSTAGE_OCR_TIMEOUT=30
# 이미지 다운로드 최대 크기 (bytes, 기본 10MB)
OCR_MAX_IMAGE_BYTES=10485760
# 이미지 다운로드 타임아웃 (초, 기본 15)
OCR_DOWNLOAD_TIMEOUT=15
# 허용할 이미지 호스트 (쉼표 구분, 비워두면 공인 IP 전체 허용)
OCR_ALLOWED_HOSTS=
